# Copy this file to .env and fill in the keys you have.
# .env is gitignored — never commit real keys.
# You can also edit these from the web UI → Réglages (Settings).
#
# Provider fallback order — LLM: Gemini → OpenAI → Anthropic → Ollama.
#                           TTS: Gemini → OpenAI → Edge (free, no key needed).
# At least one LLM key is required. With none of the paid TTS keys,
# audio still works through Edge TTS for free.

# Google Gemini — default provider (news research + scripting + optional TTS).
GEMINI_API_KEY=

# OpenAI — fallback scripting and TTS (gpt / tts-1-hd). Optional.
OPENAI_API_KEY=

# Anthropic Claude — fallback scripting. Optional.
ANTHROPIC_API_KEY=

# Ollama or any OpenAI-compatible endpoint, e.g. http://localhost:11434. Optional.
OLLAMA_API_BASE=

# ElevenLabs — premium voices. Optional.
ELEVENLABS_API_KEY=

# ---------------------------------------------------------------------------
# Email notifications (optional) — readers who subscribe to a subject get an
# email when a new episode is released. Leave SMTP_HOST empty to disable.
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Podcaster <no-reply@example.com>

# Public base URL used in notification links (and share links sent by email).
APP_BASE_URL=http://127.0.0.1:8077
